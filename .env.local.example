# Avis Google en direct (page Témoignages)
# Copiez ce fichier en ".env.local" et renseignez vos valeurs.

# Clé API Google avec "Places API (New)" activée.
# Créez-la sur https://console.cloud.google.com/ → APIs & Services → Credentials.
GOOGLE_PLACES_API_KEY=

# Identifiant de votre fiche Google (Place ID).
# Trouvez-le via https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=
